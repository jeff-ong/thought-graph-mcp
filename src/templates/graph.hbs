<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Thought Graph — {{title}}</title>
{{{vendorLibs}}}
{{{graphStyles}}}
</head>
<body>
<div id="app">
  <header>
    <h1>🧠 {{title}}</h1>
    <span class="meta">{{nodeCount}} steps · session {{shortSessionId}}</span>
    <div class="legend" id="legend"></div>
  </header>
  <button id="btnTogglePanel" class="sidebar-toggle" type="button" title="Hide step details" aria-expanded="true" aria-label="Toggle step details panel">
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
      <rect x="1.75" y="2.75" width="14.5" height="12.5" rx="2" stroke="currentColor" stroke-width="1.5"/>
      <path d="M11.5 2.75v12.5" stroke="currentColor" stroke-width="1.5"/>
    </svg>
  </button>
  <div class="graphwrap">
    <div class="toolbar">
      <button id="btnFit" title="Fit graph to screen">⤢ Fit</button>
      <button id="btnRelayout" title="Re-run the layout">↻ Re-layout</button>
      <button id="btnDownload" title="Download graph as JPG">↓ Download</button>
    </div>
    <div id="cy"></div>
  </div>
  <aside id="side">
    <h2>Step details</h2>
    <div id="detail"><p style="color:var(--muted)">Click any node to inspect that reasoning step. Hover a node to highlight its connections.</p></div>
  </aside>
</div>
<script>
const SESSION = {{{sessionJson}}};
</script>
{{{graphClientScript}}}
</body>
</html>
